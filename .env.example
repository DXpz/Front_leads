# URL base del backend (sin barra final). En local con `npm run dev` puedes dejarlo vacío y usar el proxy de Vite.
# En Vercel: Project → Settings → Environment Variables → añade VITE_API_BASE_URL (y VITE_API_KEY si aplica) para Production/Preview.
# Vite incrusta estas variables en el build; tras cambiarlas en Vercel hay que redeployar.
VITE_API_BASE_URL=http://200.35.189.139
# Copia este archivo a `.env` y define la clave (Vite solo expone variables con prefijo VITE_)
VITE_API_KEY=
